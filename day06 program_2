#include <stdio.h>
#include <maths.h>
int main()
{
    long long binary ;
    int decimal = 0, base = 1 , rem;
printf("enter the binary number: ");
    scanf("%lld", &binary);
    while (binary > 0)
    {
        rem = binary % 10;
        decimal = decimal + rem * base;
        binary = binary / 10 ;
        base = base * 2;
    }
    printf("the decimal number is: %d", decimal);
    return 0;

}