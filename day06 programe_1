#include <stdio.h>
int main()
{
    printf("enter the decimal number: ");
    scanf("%d", &n);
    while (n > 0)
    {
        r = n % 2;
        binary[i] = r;
        n = n / 2;
        i++;
    }
    printf("the binary number is: ");
    for (j = i - 1; j >= 0; j--)
    {
        printf("%d", binary[j]);
    }
    return 0;
}